# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goventurevalue

# Better Auth Configuration
# Base URL for Better Auth (used for OAuth callbacks)
# In production, set this to your production domain (e.g., https://yourdomain.com)
BETTER_AUTH_URL=http://localhost:3000
VITE_BETTER_AUTH_URL=http://localhost:3000

# Better Auth Secret (REQUIRED for production)
# Generate a secure random string: openssl rand -base64 32
# This is used for signing tokens and must be kept secret
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID with authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google (development)
#   - https://yourdomain.com/api/auth/callback/google (production)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Pitch Deck AI Providers
# Used by /pitch-decks generation flow (server reads these; restart dev server after changing)
OPENAI_API_KEY=
OPENAI_PITCH_MODEL=gpt-4.1-mini
# Get key from https://aistudio.google.com/apikey — required for Full AI and Standard deck generation
GEMINI_API_KEY=
GEMINI_PITCH_MODEL=gemini-2.0-flash
# Optional: override Gemini API version order ("v1" recommended, then "v1beta" fallback)
GEMINI_API_VERSION=v1
# Optional: comma-separated model fallback list used when the configured model is unavailable
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash

# Polar Billing (exports subscription)
POLAR_ACCESS_TOKEN=XXX
# Redirect after successful payment. Defaults to {BETTER_AUTH_URL}/billing/success when unset
POLAR_SUCCESS_URL=http://localhost:3000/billing/success
# Product ID for Better Auth checkout (e.g. exports subscription)
POLAR_EXPORTS_PRODUCT_ID=
# Optional: slug for checkout URL path (default: exports) → /api/auth/checkout/{slug}
POLAR_CHECKOUT_SLUG=exports

# Unsplash API (for Full AI pitch deck theme photo search)
# Get a free key at https://unsplash.com/developers → "New Application"
# Required for Unsplash photo search in style questionnaire; upload-only still works without it
UNSPLASH_ACCESS_KEY=